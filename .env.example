# ดึ๋งปุ๊ — environment variables (example, ไม่มี secret จริง)
# คัดลอกเป็น `.env` แล้วเติมค่าเอง (.env ไม่ขึ้น git ตาม .gitignore)
# ไฟล์นี้มีเฉพาะตัวแปรที่โค้ดอ่านจริง (grep `process.env.` ยืนยันแล้ว) — อย่าใส่ตัวแปรที่ยังไม่มีโค้ดอ่าน

# ---------- Client (build-time, ถูก bundle ลง browser — ห้ามใส่ secret) ----------
# URL ของ Colyseus realtime server ที่ client เชื่อมต่อ (src/ui/GameCanvas.tsx)
# dev local:    ws://localhost:2567
# production:   wss://<render-app>.onrender.com  (ต้อง wss:// ไม่ใช่ ws://, ตั้งตอน build client)
NEXT_PUBLIC_RT_URL=ws://localhost:2567

# ---------- Server (Colyseus, server/index.ts) ----------
# พอร์ตที่ server ฟัง — Render inject ค่านี้ให้เองตอน deploy ไม่ต้องตั้งมือ
# dev local ปล่อยว่างได้ (fallback 2567)
PORT=2567

# ---------- WS handshake security (P2-04, server/security/** + server/rooms/MapRoom.ts onAuth) ----------
# ALLOWED_ORIGINS = รายชื่อ origin ที่อนุญาตให้เปิด WS handshake (comma-separated, exact match).
#   ⛔ production **ต้องตั้ง** — เช่น https://deung-pu.softrock.space (มีหลายตัวคั่นด้วย , ได้)
#   ว่าง/ไม่ตั้ง = dev mode → อนุญาตทุก origin + log warning (ใช้เฉพาะ local; ห้ามปล่อยว่างบน production)
# ALLOWED_ORIGINS=https://deung-pu.softrock.space
#
# NODE_ENV = ตั้ง "production" บน production เพื่อ **บังคับ realtime token เสมอ** (dev/e2e ที่ไม่ตั้ง =
#   guest bypass เมื่อไม่มี token — flow local 2 แท็บ / e2e harness ยังใช้ได้). JWT_SECRET ต้องตรงกับฝั่ง Next.
# NODE_ENV=production

# ---------- Database (P2-02, Prisma + MySQL 8 — server/db/**) ----------
# ⛔ dev ใช้ MySQL **local เท่านั้น** — ห้ามชี้ production Hostinger MySQL จากที่นี่ (การต่อ prod = P2-16)
# Prisma อ่านค่านี้ (datasource url ใน prisma/schema.prisma = env("DATABASE_URL"))
# migration/generate ทำ offline ได้ (`prisma migrate diff --from-empty ...`, `prisma generate`) โดยไม่ต้องมี DB จริง
DATABASE_URL="mysql://user:pass@localhost:3306/deungpu_dev"

# ---------- Auth (P2-03, src/server/auth/** — Next API route handlers) ----------
# JWT_SECRET     = เซ็น realtime handshake token (~60s) ที่ client ขอจาก /api/auth/rt-token
#                  **แชร์กับ Colyseus server (P2-04) เพื่อ verify** — ตั้งค่าเดียวกันทั้งสองฝั่ง
# SESSION_SECRET = เซ็น httpOnly session cookie ฝั่ง Next เท่านั้น (แยกจาก JWT_SECRET โดยตั้งใจ)
# ⛔ ต้องเป็นค่าสุ่มยาว (≥16 ตัว) — โค้ด throw ถ้าว่าง/สั้นเกิน; ห้าม hardcode/commit ค่าจริง
# generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
SESSION_SECRET=

# ---------- Server — dev/test override เท่านั้น (server/rooms/MapRoom.ts) ----------
# มี default ที่ใช้งานได้อยู่แล้วในโค้ด — ห้ามตั้งค่าพวกนี้บน production
# (ใช้เปลี่ยนพฤติกรรมตอนรัน integration test / debug local เท่านั้น)
# CHANNEL_CAPACITY=8
# PARTY_CHANNEL_CAPACITY=6
# CITY_HUB_CAPACITY=80
# RECONNECT_GRACE_SECONDS=30

# ---------- หมายเหตุ ----------
# ไฟล์ .env เดิมในเครื่อง (ก่อน P1 world-sync) เคยมีชื่อ NEXT_PUBLIC_GAME_SERVER_URL —
# ชื่อนั้น**ไม่มีโค้ดอ่าน** ชื่อตัวแปรที่ถูกต้องคือ NEXT_PUBLIC_RT_URL ด้านบน (ตรวจแล้วด้วย grep
# `process.env.` ทั่ว src/) — ถ้า `.env` จริงยังมี NEXT_PUBLIC_GAME_SERVER_URL ค้างอยู่ ให้แก้ชื่อเป็น
# NEXT_PUBLIC_RT_URL ด้วยตัวเอง (ไฟล์นี้ห้าม agent แตะ .env จริงเพราะมี secret)
